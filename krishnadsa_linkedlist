write a program of split linklist ?
class Solution {
public:
    vector<ListNode*> splitListToParts(ListNode* head, int k) {
        vector<ListNode*> ans(k, NULL);

        int len = 0;
        ListNode* temp = head;

        // Count length
        while(temp) {
            len++;
            temp = temp->next;
        }

        int partSize = len / k;
        int extra = len % k;

        temp = head;

        for(int i = 0; i < k && temp; i++) {

            ans[i] = temp;

            int currSize = partSize + (extra > 0 ? 1 : 0);

            extra--;

            for(int j = 1; j < currSize; j++) {
                temp = temp->next;
            }

            ListNode* nextPart = temp->next;

            temp->next = NULL;

            temp = nextPart;
        }

        return ans;
    }
};
