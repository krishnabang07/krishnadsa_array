write a program of linklist cycle?
class Solution {
public:
    bool hasCycle(ListNode *head) {

        if(head == NULL || head->next == NULL){
            return false;
        }
        ListNode* odd = head;
        ListNode* even = head->next;

        while(even != NULL && even->next != NULL) {
            odd = odd->next;
            even = even->next->next;
            if(odd==even){
                return true;
            }
        }
                      return false;
    }
};
