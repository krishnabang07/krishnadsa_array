write a program of reverse linklist?
class Solution {
public:
    ListNode* reverseList(ListNode* head) {
        ListNode* prev = nullptr;
        ListNode* curr = head;
        
        while(curr != nullptr){
        ListNode*nexttemp=curr->next;

        curr->next=prev;

        prev=curr;
        curr=nexttemp;
        }
        return prev;
    }
};
